model User {
  id            String @id @default(uuid())

  name          String
  email         String @unique
  password      String

  phone         String?
  profileImage  String?

  role          Role

  properties     Property[]
  tenantRequests RentalRequest[] @relation("Tenant")
  ownerRequests  RentalRequest[] @relation("Landlord")
  reviews        Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


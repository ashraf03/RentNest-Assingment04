model Property {

  id String @id @default(uuid())

  title String

  description String

  rent Float

  address String

  city String

  bedrooms Int

  bathrooms Int

  availability Boolean @default(true)

  landlordId String

  landlord User @relation(fields:[landlordId], references:[id])

  categoryId String

  category Category @relation(fields:[categoryId], references:[id])

  rentalRequests RentalRequest[]

  reviews Review[]

}

